# Linker 登录账号
LINKER_USERNAME=your_username

# Linker 登录密码
LINKER_PASSWORD=your_password

# 默认提交到的项目 ID
LINKER_PROJECT_ID=1799

# 工作日志目录，程序会读取其中的 yyyy-MM-dd.md
AUTOHOUR_LOG_DIR=/absolute/path/to/your/log/dir

# 可选：daemon 模式每日执行时间，格式 HH:MM，默认 18:00
AUTOHOUR_SCHEDULE_AT=18:00

# 可选：Telegram 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 可选：SMTP 邮件通知
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_STARTTLS=true
